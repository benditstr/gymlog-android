<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.GymLog" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Akzent (Terracotta) -->
        <item name="colorPrimary">@color/accent</item>
        <item name="colorOnPrimary">@color/on_accent</item>
        <item name="colorPrimaryContainer">@color/accent_soft</item>
        <item name="colorOnPrimaryContainer">@color/accent</item>

        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/on_accent</item>
        <item name="colorSecondaryContainer">@color/accent_soft</item>
        <item name="colorOnSecondaryContainer">@color/accent</item>

        <item name="colorTertiary">@color/accent</item>
        <item name="colorOnTertiary">@color/on_accent</item>

        <!-- Hintergrund & Glass-Surfaces -->
        <item name="android:colorBackground">@color/bg_base</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorSurface">@color/bg_base</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/glass_fill</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- Outline -->
        <item name="colorOutline">@color/glass_border</item>
        <item name="colorOutlineVariant">@color/glass_border</item>

        <!-- Error -->
        <item name="colorError">@color/error_color</item>
        <item name="colorOnError">@color/bg_base</item>

        <!-- Standard-Schrift: Inter -->
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>

        <!-- Status-/Navigationsleiste -->
        <item name="android:statusBarColor">@color/bg_base</item>
        <item name="android:navigationBarColor">@color/bg_base</item>
    </style>

    <style name="Theme.GymLog" parent="Base.Theme.GymLog" />

    <!-- ══ TextAppearances (Spec 1.2) ══ -->
    <style name="TextAppearance.GymLog.Headline" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:fontFamily">@font/fraunces</item>
        <item name="fontFamily">@font/fraunces</item>
        <item name="android:textFontWeight" tools:targetApi="28">600</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.GymLog.Label" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:textFontWeight" tools:targetApi="28">500</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.GymLog.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.GymLog.Value" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:textFontWeight" tools:targetApi="28">700</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:fontFeatureSettings">tnum</item>
    </style>

    <!-- ══ Buttons (Spec 3) ══ -->
    <style name="Widget.GymLog.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/on_accent</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textFontWeight" tools:targetApi="28">700</item>
        <item name="cornerRadius">11dp</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Widget.GymLog.Button.Ghost" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="cornerRadius">11dp</item>
    </style>

    <!-- ══ Glass-Dialog (Spec 3) ══ -->
    <style name="ThemeOverlay.GymLog.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="dialogCornerRadius">16dp</item>
        <item name="colorSurface">@color/bg_surface_high</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <item name="materialAlertDialogTitleTextStyle">@style/TextAppearance.GymLog.Headline</item>
    </style>

    <!-- Glass-TextInput -->
    <style name="Widget.GymLog.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/accent</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
    </style>
</resources>
