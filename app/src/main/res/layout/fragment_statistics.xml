<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="end"
        android:layout_marginTop="-120dp"
        android:layout_marginEnd="-100dp"
        android:background="@drawable/bg_glow" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="18dp"
        android:paddingBottom="96dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="14dp"
            android:text="@string/title_stats"
            android:fontFamily="@font/fraunces"
            android:textAppearance="@style/TextAppearance.GymLog.Headline"
            android:textSize="24sp" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_exercise_stats"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_exercise">

            <AutoCompleteTextView
                android:id="@+id/dropdown_exercise_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:inputType="none"
                android:textColor="@color/text_primary"
                android:popupBackground="@color/bg_surface_high" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Personal Record Glass-Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_personal_record"
                android:textAppearance="@style/TextAppearance.GymLog.Label" />

            <TextView
                android:id="@+id/tv_pr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/fraunces"
                android:fontFeatureSettings="tnum"
                android:text="@string/label_no_record"
                android:textAppearance="@style/TextAppearance.GymLog.Headline"
                android:textColor="@color/accent"
                android:textSize="34sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"
            android:text="@string/label_chart_hint"
            android:textAppearance="@style/TextAppearance.GymLog.Label" />

        <!-- Chart Glass-Card -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_glass_card"
            android:padding="12dp">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/line_chart"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/tv_empty_stats"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:text="@string/empty_stats"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
