<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_base">

    <!-- Dekorativer Akzent-Glow (oben links) -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_marginStart="-90dp"
        android:layout_marginTop="-110dp"
        android:background="@drawable/bg_glow" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Hero Glass-Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_eyebrow_today"
                        android:textAppearance="@style/TextAppearance.GymLog.Label" />

                    <TextView
                        android:id="@+id/tv_today_day"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/fraunces"
                        android:textAppearance="@style/TextAppearance.GymLog.Headline"
                        android:textSize="30sp" />

                    <TextView
                        android:id="@+id/tv_today_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Streak-Badge -->
                <LinearLayout
                    android:id="@+id/streak_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_streak_badge"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="9dp"
                    android:paddingTop="5dp"
                    android:paddingEnd="9dp"
                    android:paddingBottom="5dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="5dp"
                        android:src="@drawable/ic_streak"
                        android:contentDescription="@string/home_streak_desc" />

                    <TextView
                        android:id="@+id/tv_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFeatureSettings="tnum" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_today_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Section-Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="8dp"
            android:text="@string/label_last_entries"
            android:textAppearance="@style/TextAppearance.GymLog.Label" />

        <TextView
            android:id="@+id/tv_empty_home"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:text="@string/empty_entries"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_last_entries"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingTop="2dp"
            android:paddingBottom="96dp" />
    </LinearLayout>
</FrameLayout>
